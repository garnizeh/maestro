{
  "cniVersion": "1.1.0",
  "name": "beam0",
  "plugins": [
    {
      "type": "bridge",
      "bridge": "beam0",
      "isGateway": true,
      "ipMasq": true,
      "hairpinMode": true,
      "ipam": {
        "type": "host-local",
        "subnet": "10.99.0.0/16",
        "routes": [
          { "dst": "0.0.0.0/0" }
        ]
      }
    },
    {
      "type": "firewall"
    },
    {
      "type": "portmap",
      "capabilities": {"portMappings": true}
    }
  ]
}
